# Backend environment variables (Render)
# Render injects PORT automatically in production; keep this for local development.
PORT=5000

# Set to true only for local debugging.
FLASK_DEBUG=false

# Required Etherscan settings.
ETHERSCAN_API_KEY=your_etherscan_api_key
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_CHAIN_ID=1

# Required data/model settings.
TRANSACTION_DATASET_PATH=../data/transaction_dataset.csv
WALLET_ML_MODEL_DIR=./models
WALLET_ML_MODEL_PATH=./models/wallet_risk_model.joblib
ANALYTICS_SAMPLE_SIZE=140
ETH_USD_PRICE=3500
