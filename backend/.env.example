# Backend environment variables (Render)
# Render injects PORT automatically in production; keep this for local development.
PORT=5000

# Set to true only for local debugging.
FLASK_DEBUG=false

# Primary transaction source (higher throughput than Etherscan free tier).
BLOCKSCOUT_BASE_URL=https://eth.blockscout.com/api/v2
BLOCKSCOUT_PAGE_SIZE=100
BLOCKSCOUT_MAX_TX=5000

# Optional Etherscan fallback (used only if Blockscout fails).
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_CHAIN_ID=1

# Required data/model settings.
TRANSACTION_DATASET_PATH=../data/transaction_dataset.csv
WALLET_ML_MODEL_DIR=./models
WALLET_ML_MODEL_PATH=./models/wallet_risk_model.joblib
ANALYTICS_SAMPLE_SIZE=140
ETH_USD_PRICE=3500

# Optional threat-intelligence providers.
# Bitcoin Abuse API: used for BTC-format address checks.
BITCOIN_ABUSE_API_URL=https://www.bitcoinabuse.com/api/reports/check
BITCOIN_ABUSE_API_KEY=

# Chainabuse API: set URL + key to enable external checks.
# If your endpoint path already includes the wallet, use {address} placeholder.
# Example: https://api.chainabuse.com/v1/reports/{address}
CHAINABUSE_API_URL=
CHAINABUSE_API_KEY=

# Optional Chainabuse response mapping for account-specific schemas.
# Dot-path to list of report rows (e.g. data.reports.items)
CHAINABUSE_REPORTS_PATH=
# Dot-path to total count (used if reports path not available)
CHAINABUSE_COUNT_PATH=
# Comma-separated report fields that may contain wallet address
CHAINABUSE_ADDRESS_FIELDS=address,walletAddress,wallet_address,identifier,value
